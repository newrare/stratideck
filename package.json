{
  "name": "stratideck",
  "version": "0.1.0",
  "description": "A mobile game blending deck building with grid-based defense strategy",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
