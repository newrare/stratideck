    "@capacitor/ios": "^6.0.0",
    "@capacitor/screen-orientation": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.3.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
